generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EXECUTIVE
  PROJECT_MANAGER
  ENGINEER
  FINANCE
  PROCUREMENT
  QAQC
  MAINTENANCE
}

enum HealthStatus {
  ON_TRACK
  AT_RISK
  DELAYED
  CRITICAL
}

enum RevenueStatus {
  NOT_BILLED
  PARTIALLY_BILLED
  BILLED
  OVERDUE
  AT_RISK
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  PAID
  OVERDUE
}

enum TenderStage {
  ENQUIRY
  INTERNAL_REVIEW
  COSTING
  RISK_REVIEW
  APPROVAL_PENDING
  APPROVED_TO_BID
  SUBMITTED
  AWARDED
  LOST
  CANCELLED
  NO_BID
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ENGINEER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedProjects Project[] @relation("ProjectManager")
}

model Project {
  id         String @id @default(cuid())
  code       String @unique
  name       String
  clientName String

  // Keep this for now because your existing data/API may already use it.
  // Store values like: its, traffic, its-maint, traffic-maint
  portfolio String

  // Proper relation to PortfolioCategory
  portfolioCategoryId String?
  portfolioCategory   PortfolioCategory? @relation(fields: [portfolioCategoryId], references: [id], onDelete: SetNull)

  projectManagerId String?
  contractValue    Decimal? @db.Decimal(18, 2)

  completionPct   Int          @default(0)
  plannedProgress Int          @default(0)
  actualProgress  Int          @default(0)
  healthStatus    HealthStatus @default(ON_TRACK)

  // Dashboard fields for portfolio overview
  delayedApprovals   Int      @default(0)
  blockedItems       Int      @default(0)
  billingReadyAmount Decimal? @db.Decimal(18, 2)
  topIssue           String?
  topIssueAgeDays    Int?

  plannedStart   DateTime?
  plannedFinish  DateTime?
  forecastFinish DateTime?
  status         RecordStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectManager User? @relation("ProjectManager", fields: [projectManagerId], references: [id])

  tenders          Tender[]
  documents        PlanningDocument[]
  activities       PlanningActivity[]
  milestones       PlanningMilestone[]
  resources        PlanningResource[]
  inspections      Inspection[]
  ncrs             Ncr[]
  materialRequests MaterialRequest[]
  purchaseOrders   PurchaseOrder[]
  assets           Asset[]

  // Revenue & billing
  invoices Invoice[]
  billing  ProjectBilling? @relation("ProjectBillingRelation")

  @@index([portfolio])
  @@index([portfolioCategoryId])
  @@index([status])
  @@index([healthStatus])
}

model PortfolioCategory {
  id           String  @id @default(uuid())
  code         String  @unique
  name         String  @unique
  description  String?
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model Invoice {
  id        String @id @default(cuid())
  invoiceNo String @unique
  projectId String

  amount Decimal       @db.Decimal(18, 2)
  status InvoiceStatus @default(DRAFT)

  issueDate DateTime?
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  items InvoiceItem[]

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String

  description String
  amount      Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ProjectBilling {
  id        String @id @default(uuid())
  projectId String @unique

  project Project @relation("ProjectBillingRelation", fields: [projectId], references: [id], onDelete: Cascade)

  contractValue      Decimal? @db.Decimal(18, 2)
  invoicedToDate     Decimal? @db.Decimal(18, 2)
  billingReadyAmount Decimal? @db.Decimal(18, 2)
  overdueReceivables Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentationStageLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  documents PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model DocumentApprovalStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  severity     String?
  isActive     Boolean @default(true)

  documents PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model ProjectHealthStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  severity     String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model MilestoneStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  severity     String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model ActivitySeverityLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model Tender {
  id                 String       @id @default(cuid())
  refNo              String       @unique
  title              String
  clientName         String
  source             String?
  estimatedValue     Decimal?     @db.Decimal(18, 2)
  bidValue           Decimal?     @db.Decimal(18, 2)
  stage              TenderStage  @default(ENQUIRY)
  submissionDeadline DateTime?
  projectId          String?
  owner              String?
  riskScore          Int?
  marginPct          Decimal?     @db.Decimal(5, 2)
  status             RecordStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([stage])
  @@index([status])
}

model PlanningDocument {
  id        String @id @default(cuid())
  projectId String
  fileName  String
  revision  String
  planType  String @default("BASELINE")

  stageCode          String @default("pre-construction")
  approvalStatusCode String @default("in-preparation")

  approver    String?
  submittedAt DateTime?
  dueDate     DateTime?
  approvedAt  DateTime?

  count Int @default(1)

  baselineStart  DateTime?
  baselineFinish DateTime?
  forecastFinish DateTime?
  status         RecordStatus @default(ACTIVE)

  uploadedBy String?
  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stage          DocumentationStageLookup     @relation(fields: [stageCode], references: [code])
  approvalStatus DocumentApprovalStatusLookup @relation(fields: [approvalStatusCode], references: [code])

  activities PlanningActivity[]
  milestones PlanningMilestone[]
  resources  PlanningResource[]

  @@index([projectId])
  @@index([stageCode])
  @@index([approvalStatusCode])
  @@index([status])
  @@index([dueDate])
  @@index([approvedAt])
}

model PlanningActivity {
  id              String       @id @default(cuid())
  projectId       String
  documentId      String?
  wbsCode         String?
  activityId      String
  activityName    String
  discipline      String?
  location        String?
  durationDays    Int?
  plannedStart    DateTime?
  plannedFinish   DateTime?
  actualStart     DateTime?
  actualFinish    DateTime?
  floatDays       Int?
  percentComplete Int          @default(0)
  owner           String?
  isCritical      Boolean      @default(false)
  healthStatus    HealthStatus @default(ON_TRACK)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([projectId, activityId])
  @@index([projectId])
  @@index([activityId])
  @@index([wbsCode])
  @@index([healthStatus])
}

model PlanningMilestone {
  id             String       @id @default(cuid())
  projectId      String
  documentId     String?
  milestoneCode  String?
  milestoneName  String
  baselineDate   DateTime?
  forecastDate   DateTime?
  actualDate     DateTime?
  delayDays      Int          @default(0)
  linkedActivity String?
  healthStatus   HealthStatus @default(ON_TRACK)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
  @@index([healthStatus])
  @@index([delayDays])
}

model PlanningResource {
  id           String       @id @default(cuid())
  projectId    String
  documentId   String?
  activityId   String?
  resourceRole String
  resourceName String?
  plannedQty   Int          @default(0)
  availableQty Int          @default(0)
  requiredDate DateTime?
  healthStatus HealthStatus @default(ON_TRACK)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
  @@index([activityId])
  @@index([healthStatus])
}

model Inspection {
  id             String       @id @default(cuid())
  refNo          String       @unique
  projectId      String
  activity       String
  inspectionType String?
  inspectorName  String?
  scheduledAt    DateTime?
  outcome        String?
  healthStatus   HealthStatus @default(ON_TRACK)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model Ncr {
  id           String       @id @default(cuid())
  refNo        String       @unique
  projectId    String
  description  String
  packageName  String?
  raisedBy     String?
  severity     String?
  healthStatus HealthStatus @default(AT_RISK)
  dateRaised   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model MaterialRequest {
  id           String       @id @default(cuid())
  refNo        String       @unique
  projectId    String
  materialName String
  quantity     String?
  requestedBy  String?
  priority     String?
  healthStatus HealthStatus @default(ON_TRACK)
  requestDate  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model PurchaseOrder {
  id               String       @id @default(cuid())
  refNo            String       @unique
  projectId        String
  vendorName       String
  materialName     String
  amount           Decimal?     @db.Decimal(18, 2)
  issuedAt         DateTime?
  expectedDelivery DateTime?
  healthStatus     HealthStatus @default(ON_TRACK)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model Asset {
  id           String       @id @default(cuid())
  assetCode    String       @unique
  projectId    String
  name         String
  assetType    String
  location     String?
  healthStatus HealthStatus @default(ON_TRACK)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}
