generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * --------------------------------------------------------------------------
 * ENUMS
 * --------------------------------------------------------------------------
 */

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EXECUTIVE
  PROJECT_MANAGER
  ENGINEER
  FINANCE
  PROCUREMENT
  QAQC
  MAINTENANCE
}

enum HealthStatus {
  ON_TRACK
  AT_RISK
  DELAYED
  CRITICAL
}

enum RevenueStatus {
  NOT_BILLED
  PARTIALLY_BILLED
  BILLED
  OVERDUE
  AT_RISK
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  PAID
  OVERDUE
}

enum TenderStage {
  ENQUIRY
  INTERNAL_REVIEW
  COSTING
  RISK_REVIEW
  APPROVAL_PENDING
  APPROVED_TO_BID
  SUBMITTED
  AWARDED
  LOST
  CANCELLED
  NO_BID
}

enum MaterialAvailabilityStatus {
  NOT_ASSESSED
  AVAILABLE
  PARTIAL
  SHORTAGE
}

enum MaterialDeliveryStatus {
  NOT_PLANNED
  DELIVERED
  PENDING
  DELAYED
}

enum LabourReadinessStatus {
  NOT_ASSESSED
  FULL_CREW
  SHORT
}


enum ScheduleUploadStatus {
  PROCESSING
  VALIDATED
  IMPORTED
  FAILED
  PARTIAL
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  DELAYED
  BLOCKED
  ON_HOLD
}

enum ResourceType {
  RESOURCE
  PERSON
  TEAM
  SITE_ENGINEER
  FIELD_ENGINEER
  SUPERVISOR
  CREW
  TECHNICIAN
  EQUIPMENT
  MATERIAL
  VENDOR
  SUBCONTRACTOR
}

enum ScheduleLocationSource {
  NONE
  EXCEL_PARENT_ROW
  EXCEL_WORK_SECTION
  MANUAL
}

enum ResourceAssignmentScope {
  PROJECT
  ROAD_LOCATION
  WBS_ITEM
  ACTIVITY
  PACKAGE
}

enum ActivityAssignmentStatus {
  UNASSIGNED
  PARTIALLY_ASSIGNED
  ASSIGNED
}

enum ResourceAvailabilityStatus {
  AVAILABLE
  HIGH_LOAD
  OVER_ALLOCATED
}

enum DocumentImportSource {
  MANUAL
  EXCEL_IMPORT
}

/**
 * --------------------------------------------------------------------------
 * USERS
 * --------------------------------------------------------------------------
 */

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ENGINEER)
  department   String?
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProjects Project[] @relation("ProjectManager")

  scheduleUploads ProjectScheduleUpload[] @relation("ScheduleUploadUser")

  // Optional link to Resource.
  // Useful when a mobile app user is also a field engineer/resource.
  resources Resource[]

  @@index([role])
  @@index([isActive])
  @@index([email])
}

/**
 * --------------------------------------------------------------------------
 * CLIENT MASTER
 * --------------------------------------------------------------------------
 */

model Client {
  id          String  @id @default(cuid())
  name        String  @unique
  email       String?
  phone       String?
  address     String?
  contactName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@index([name])
}

/**
 * --------------------------------------------------------------------------
 * LOCATION / ROAD MASTER
 * --------------------------------------------------------------------------
 */

model RoadLocation {
  id String @id @default(cuid())

  name           String
  normalizedName String
  roadCode       String

  // PostgreSQL supports scalar lists.
  // Store alternate names like AL KHAIL ST, AL KHAIL STREET, etc.
  aliases String[] @default([])

  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectLinks ProjectRoadLocation[]

  wbsItems           WbsItem[]
  scheduleActivities ScheduleActivity[]
  milestones         Milestone[]

  planningActivities PlanningActivity[]
  planningMilestones PlanningMilestone[]

  projectResourceAssignments  ProjectResourceAssignment[]
  activityResourceAssignments ActivityResourceAssignment[]

  assets Asset[]

  // roadCode is NOT unique because multiple streets can share D68, D83, E44, etc.
  @@unique([normalizedName, roadCode])
  @@index([roadCode])
  @@index([normalizedName])
  @@index([isActive])
}

model ProjectRoadLocation {
  id String @id @default(cuid())

  projectId      String
  roadLocationId String

  createdAt DateTime @default(now())

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roadLocation RoadLocation @relation(fields: [roadLocationId], references: [id], onDelete: Cascade)

  @@unique([projectId, roadLocationId])
  @@index([projectId])
  @@index([roadLocationId])
}

/**
 * --------------------------------------------------------------------------
 * PROJECT
 * --------------------------------------------------------------------------
 */

model Project {
  id         String @id @default(cuid())
  code       String @unique
  name       String
  clientName String

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Existing portfolio string retained for compatibility.
  portfolio String

  portfolioCategoryId String?
  portfolioCategory   PortfolioCategory? @relation(fields: [portfolioCategoryId], references: [id], onDelete: SetNull)

  projectManagerId String?
  projectManager   User?   @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)

  contractValue Decimal? @db.Decimal(18, 2)

  completionPct   Int          @default(0)
  plannedProgress Int          @default(0)
  actualProgress  Int          @default(0)
  healthStatus    HealthStatus @default(ON_TRACK)

  delayedApprovals   Int      @default(0)
  blockedItems       Int      @default(0)
  billingReadyAmount Decimal? @db.Decimal(18, 2)
  topIssue           String?
  topIssueAgeDays    Int?

  plannedStart   DateTime?
  plannedFinish  DateTime?
  forecastFinish DateTime?

  contractStartDate DateTime?
  contractEndDate   DateTime?

  status RecordStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenders          Tender[]
  documents        PlanningDocument[]
  activities       PlanningActivity[]
  milestones       PlanningMilestone[]
  resources        PlanningResource[]
  inspections      Inspection[]
  ncrs             Ncr[]
  materialRequests MaterialRequest[]
  purchaseOrders   PurchaseOrder[]
  assets           Asset[]

  invoices Invoice[]
  billing  ProjectBilling? @relation("ProjectBillingRelation")

  scheduleUploads             ProjectScheduleUpload[]
  wbsItems                    WbsItem[]
  scheduleActivities          ScheduleActivity[]
  scheduleMilestones          Milestone[]
  scheduleResourceAssignments ActivityResourceAssignment[]

  roadLocations ProjectRoadLocation[]

  // General project/street/field engineer assignment model.
  projectResourceAssignments ProjectResourceAssignment[]

  @@index([clientId])
  @@index([portfolio])
  @@index([portfolioCategoryId])
  @@index([projectManagerId])
  @@index([status])
  @@index([healthStatus])
}

/**
 * --------------------------------------------------------------------------
 * PORTFOLIO CATEGORY
 * --------------------------------------------------------------------------
 */

model PortfolioCategory {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String  @unique
  description  String?
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

/**
 * --------------------------------------------------------------------------
 * SCHEDULE UPLOAD / IMPORT MODELS
 * --------------------------------------------------------------------------
 */

model ProjectScheduleUpload {
  id String @id @default(cuid())

  projectId String
  fileName  String

  revisionNo Int

  uploadedById String?
  uploadedAt   DateTime @default(now())

  status ScheduleUploadStatus @default(PROCESSING)

  totalRows Int @default(0)
  validRows Int @default(0)
  errorRows Int @default(0)

  sheetName  String?
  fileSize   Int?
  importedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  uploadedBy User? @relation("ScheduleUploadUser", fields: [uploadedById], references: [id], onDelete: SetNull)

  wbsItems   WbsItem[]
  activities ScheduleActivity[]
  milestones Milestone[]
  errors     ScheduleImportError[]

  @@unique([projectId, revisionNo])
  @@index([projectId])
  @@index([uploadedById])
  @@index([status])
  @@index([uploadedAt])
}

model WbsItem {
  id String @id @default(cuid())

  projectId String
  uploadId  String

  parentId String?

  wbsCode  String
  wbsLevel Int?
  name     String

  startDate  DateTime?
  finishDate DateTime?
  duration   Int?
  totalFloat Int?

  rowNumber Int?

  // Location context from Excel hierarchy.
  // Example row: AL KHAIL STREET
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  rawLocationName String?
  rawRoadCode     String?

  locationSource ScheduleLocationSource @default(NONE)

  project Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  upload  ProjectScheduleUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  parent   WbsItem?  @relation("WbsHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children WbsItem[] @relation("WbsHierarchy")

  activities ScheduleActivity[]

  projectResourceAssignments ProjectResourceAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([uploadId, wbsCode])
  @@index([projectId])
  @@index([uploadId])
  @@index([parentId])
  @@index([wbsCode])
  @@index([wbsLevel])
  @@index([roadLocationId])
}

model ScheduleActivity {
  id String @id @default(cuid())

  projectId String
  uploadId  String
  wbsItemId String?

  activityCode String
  activityName String

  duration   Int?
  startDate  DateTime?
  finishDate DateTime?
  totalFloat Int?

  isMilestone Boolean @default(false)
  isCritical  Boolean @default(false)

  status ActivityStatus @default(NOT_STARTED)

  rowNumber Int?

  // Location fields for mobile filtering.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  rawLocationName String?
  rawRoadCode     String?

  // Useful parsed context from Excel hierarchy.
  packageName     String?
  workSectionName String?
  assetReference  String?

  locationSource ScheduleLocationSource @default(NONE)

  project Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  upload  ProjectScheduleUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  wbsItem WbsItem? @relation(fields: [wbsItemId], references: [id], onDelete: SetNull)

  milestone Milestone?

  resourceAssignments ActivityResourceAssignment[]
  statusUpdates       ActivityStatusUpdate[]
  taskProgressUpdates TaskProgressUpdate[]

  projectResourceAssignments ProjectResourceAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([uploadId, activityCode])
  @@index([projectId])
  @@index([uploadId])
  @@index([wbsItemId])
  @@index([activityCode])
  @@index([status])
  @@index([isMilestone])
  @@index([isCritical])
  @@index([startDate])
  @@index([finishDate])
  @@index([roadLocationId])
  @@index([rawRoadCode])
}

model Milestone {
  id String @id @default(cuid())

  projectId  String
  uploadId   String
  activityId String @unique

  milestoneCode String
  name          String

  plannedDate DateTime?
  actualDate  DateTime?

  status ActivityStatus @default(NOT_STARTED)

  // Location fields inherited from related schedule activity.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  rawLocationName String?
  rawRoadCode     String?
  packageName     String?
  workSectionName String?
  assetReference  String?

  locationSource ScheduleLocationSource @default(NONE)

  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  upload   ProjectScheduleUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  activity ScheduleActivity      @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([uploadId, milestoneCode])
  @@index([projectId])
  @@index([uploadId])
  @@index([status])
  @@index([plannedDate])
  @@index([roadLocationId])
}

model ScheduleImportError {
  id String @id @default(cuid())

  uploadId String

  sheetName    String?
  rowNumber    Int
  columnName   String?
  errorMessage String
  rawValue     String?

  upload ProjectScheduleUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([uploadId])
  @@index([rowNumber])
  @@index([columnName])
}

/**
 * --------------------------------------------------------------------------
 * RESOURCE / FIELD EXECUTION MODELS
 * --------------------------------------------------------------------------
 */

model Resource {
  id String @id @default(cuid())

  employeeCode String? @unique

  name String
  type ResourceType @default(RESOURCE)

  discipline   String?
  designation  String?

  email String?
  phone String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  activityAssignments ActivityResourceAssignment[]
  projectAssignments  ProjectResourceAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([discipline])
  @@index([designation])
  @@index([isActive])
  @@index([email])
  @@index([userId])
}

model ProjectResourceAssignment {
  id String @id @default(cuid())

  projectId  String
  resourceId String

  // Optional scope fields.
  // This allows assignment at project, road, WBS, package, or activity level.
  scope ResourceAssignmentScope @default(PROJECT)

  roadLocationId     String?
  wbsItemId          String?
  scheduleActivityId String?

  packageName     String?
  workSectionName String?

  plannedStart  DateTime?
  plannedFinish DateTime?

  remarks String?

  isActive Boolean @default(true)

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  roadLocation     RoadLocation?     @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)
  wbsItem          WbsItem?          @relation(fields: [wbsItemId], references: [id], onDelete: SetNull)
  scheduleActivity ScheduleActivity? @relation(fields: [scheduleActivityId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([resourceId])
  @@index([scope])
  @@index([roadLocationId])
  @@index([wbsItemId])
  @@index([scheduleActivityId])
  @@index([plannedStart])
  @@index([plannedFinish])
  @@index([isActive])
}

model ActivityResourceAssignment {
  id String @id @default(cuid())

  projectId  String
  activityId String
  resourceId String

  // Optional direct location reference.
  // Usually this should match activity.roadLocationId.
  // Kept here to make field/mobile filtering faster and simpler.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  allocation   Float?
  quantity     Float?
  unit         String?
  plannedHours Float?
  actualHours  Float?

  plannedStart  DateTime?
  plannedFinish DateTime?
  remarks       String?
  labourStatus LabourReadinessStatus @default(NOT_ASSESSED)

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activity ScheduleActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  resource Resource         @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([activityId, resourceId])
  @@index([projectId])
  @@index([activityId])
  @@index([resourceId])
  @@index([roadLocationId])
  @@index([plannedStart])
  @@index([plannedFinish])
  @@index([labourStatus])
}

model ActivityStatusUpdate {
  id String @id @default(cuid())

  scheduleActivityId String

  status             ActivityStatus
  progressPercentage Float?
  remarks            String?
  progressColorClass String?
  statusBadgeClass   String?

  uploadedFileUrl  String?
  uploadedFileName String?
  uploadedFileType String?

  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduleActivity ScheduleActivity @relation(fields: [scheduleActivityId], references: [id], onDelete: Cascade)

  @@index([scheduleActivityId])
  @@index([status])
  @@index([updatedAt])
}

/**
 * /**
 * Task Progress
 */

model TaskProgressUpdate {
  id String @id @default(cuid())

  scheduleActivityId String

  progressPercentage Float          @default(0)
  status             ActivityStatus
  remarks            String?

  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scheduleActivity ScheduleActivity @relation(fields: [scheduleActivityId], references: [id], onDelete: Cascade)

  @@index([scheduleActivityId])
  @@index([status])
  @@index([createdAt])
}

/**
 * --------------------------------------------------------------------------
 * DOCUMENT STATUS MODELS
 * --------------------------------------------------------------------------
 */

model DocumentDisciplineLookup {
  code         String  @id
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  planningDocuments PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

model DocumentOwnerLookup {
  code         String  @id
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  planningDocuments PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

model DocumentWorkflowStatusLookup {
  code         String  @id
  label        String
  tone         String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  planningDocuments PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([displayOrder])
}

/**
 * --------------------------------------------------------------------------
 * INVOICING
 * --------------------------------------------------------------------------
 */

model Invoice {
  id        String @id @default(cuid())
  invoiceNo String @unique
  projectId String

  amount Decimal       @db.Decimal(18, 2)
  status InvoiceStatus @default(DRAFT)

  issueDate DateTime?
  dueDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  items InvoiceItem[]

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String

  description String
  amount      Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ProjectBilling {
  id        String @id @default(cuid())
  projectId String @unique

  project Project @relation("ProjectBillingRelation", fields: [projectId], references: [id], onDelete: Cascade)

  contractValue      Decimal? @db.Decimal(18, 2)
  invoicedToDate     Decimal? @db.Decimal(18, 2)
  billingReadyAmount Decimal? @db.Decimal(18, 2)
  overdueReceivables Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

}

/**
 * --------------------------------------------------------------------------
 * LOOKUPS
 * --------------------------------------------------------------------------
 */

model DocumentationStageLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  documents PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model DocumentApprovalStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  severity     String?
  isActive     Boolean @default(true)

  documents PlanningDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model ProjectHealthStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  severity     String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model MilestoneStatusLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  severity     String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model ActivitySeverityLookup {
  id           String  @id @default(cuid())
  code         String  @unique
  label        String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@index([displayOrder])
}

model RolePermission {
  id String @id @default(cuid())

  role UserRole @unique

  adminView   Boolean @default(false)
  adminCreate Boolean @default(false)
  adminEdit   Boolean @default(false)
  adminDelete Boolean @default(false)

  executiveDashboardView Boolean @default(false)

  pmDashboardView Boolean @default(false)

  projectView   Boolean @default(false)
  projectCreate Boolean @default(false)
  projectEdit   Boolean @default(false)
  projectDelete Boolean @default(false)

  planningView   Boolean @default(false)
  planningCreate Boolean @default(false)
  planningEdit   Boolean @default(false)
  planningDelete Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

/**
 * --------------------------------------------------------------------------
 */
/**
 * SystemSetting
 */
/**
 * --------------------------------------------------------------------------
 */

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  value       String
  category    String
  status      String   @default("Active")
  description String?
  isEditable  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/**
 * --------------------------------------------------------------------------
 * TENDERS
 * --------------------------------------------------------------------------
 */

model Tender {
  id                 String       @id @default(cuid())
  refNo              String       @unique
  title              String
  clientName         String
  source             String?
  estimatedValue     Decimal?     @db.Decimal(18, 2)
  bidValue           Decimal?     @db.Decimal(18, 2)
  stage              TenderStage  @default(ENQUIRY)
  submissionDeadline DateTime?
  projectId          String?
  owner              String?
  riskScore          Int?
  marginPct          Decimal?     @db.Decimal(5, 2)
  status             RecordStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([stage])
  @@index([status])
}

/**
 * --------------------------------------------------------------------------
 * DOCUMENTATION / PLANNING
 * --------------------------------------------------------------------------
 */

model PlanningDocument {
  id        String @id @default(cuid())
  projectId String
  fileName  String
  revision  String
  planType  String @default("BASELINE")

  stageCode          String @default("pre-construction")
  approvalStatusCode String @default("in-preparation")

  approver    String?
  submittedAt DateTime?
  dueDate     DateTime?
  approvedAt  DateTime?

  count Int @default(1)

  baselineStart  DateTime?
  baselineFinish DateTime?
  forecastFinish DateTime?
  status         RecordStatus @default(ACTIVE)

  uploadedBy String?
  uploadedAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stage          DocumentationStageLookup     @relation(fields: [stageCode], references: [code])
  approvalStatus DocumentApprovalStatusLookup @relation(fields: [approvalStatusCode], references: [code])

  activities PlanningActivity[]
  milestones PlanningMilestone[]
  resources  PlanningResource[]

  documentNo String?
  title      String?

  documentType     String?
  documentCategory String?
  documentTypeCode String?
  packageName      String?
  delayIndicator   String?

  disciplineCode String?
  discipline     DocumentDisciplineLookup? @relation(fields: [disciplineCode], references: [code])

  ownerCode String?
  owner     DocumentOwnerLookup? @relation(fields: [ownerCode], references: [code])

  workflowStatusCode String?                       @default("draft")
  workflowStatus     DocumentWorkflowStatusLookup? @relation(fields: [workflowStatusCode], references: [code])

  progressPct Int @default(0)

  lastUpdate String?
  remarks    String?

  importSource DocumentImportSource @default(MANUAL)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([stageCode])
  @@index([approvalStatusCode])
  @@index([status])
  @@index([dueDate])
  @@index([approvedAt])
}

model PlanningActivity {
  id String @id @default(cuid())

  projectId  String
  documentId String?

  wbsCode      String?
  activityId   String
  activityName String

  discipline String?

  // Existing text location retained for compatibility.
  location String?

  // New proper location relation.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  rawLocationName String?
  rawRoadCode     String?
  packageName     String?
  workSectionName String?
  assetReference  String?

  locationSource ScheduleLocationSource @default(NONE)

  durationDays Int?

  plannedStart  DateTime?
  plannedFinish DateTime?
  actualStart   DateTime?
  actualFinish  DateTime?

  floatDays       Int?
  percentComplete Int  @default(0)

  owner      String?
  isCritical Boolean @default(false)

  healthStatus HealthStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([projectId, activityId])
  @@index([projectId])
  @@index([documentId])
  @@index([activityId])
  @@index([wbsCode])
  @@index([healthStatus])
  @@index([roadLocationId])
  @@index([rawRoadCode])
}

model PlanningMilestone {
  id String @id @default(cuid())

  projectId  String
  documentId String?

  milestoneCode String?
  milestoneName String

  baselineDate DateTime?
  forecastDate DateTime?
  actualDate   DateTime?

  delayDays      Int     @default(0)
  linkedActivity String?

  // New location relation.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  rawLocationName String?
  rawRoadCode     String?
  packageName     String?
  workSectionName String?
  assetReference  String?

  locationSource ScheduleLocationSource @default(NONE)

  healthStatus HealthStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
  @@index([healthStatus])
  @@index([delayDays])
  @@index([roadLocationId])
}

model PlanningResource {
  id String @id @default(cuid())

  projectId  String
  documentId String?

  activityId String?

  resourceRole String
  resourceName String?

  plannedQty   Int @default(0)
  availableQty Int @default(0)

  requiredDate DateTime?

  healthStatus HealthStatus @default(ON_TRACK)
  materialStatus MaterialAvailabilityStatus @default(NOT_ASSESSED)
  deliveryStatus MaterialDeliveryStatus @default(NOT_PLANNED)
  labourStatus   LabourReadinessStatus @default(NOT_ASSESSED)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt


  project  Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document PlanningDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([documentId])
  @@index([activityId])
  @@index([healthStatus])
  @@index([materialStatus])
  @@index([deliveryStatus]) 
   @@index([labourStatus])
}

/**
 * --------------------------------------------------------------------------
 * QA/QC
 * --------------------------------------------------------------------------
 */

model Inspection {
  id             String       @id @default(cuid())
  refNo          String       @unique
  projectId      String
  activity       String
  inspectionType String?
  inspectorName  String?
  scheduledAt    DateTime?
  outcome        String?
  healthStatus   HealthStatus @default(ON_TRACK)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model Ncr {
  id           String       @id @default(cuid())
  refNo        String       @unique
  projectId    String
  description  String
  packageName  String?
  raisedBy     String?
  severity     String?
  healthStatus HealthStatus @default(AT_RISK)
  dateRaised   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

/**
 * --------------------------------------------------------------------------
 * PROCUREMENT / MATERIALS
 * --------------------------------------------------------------------------
 */

model MaterialRequest {
  id           String       @id @default(cuid())
  refNo        String       @unique
  projectId    String
  materialName String
  quantity     String?
  requestedBy  String?
  priority     String?
  healthStatus HealthStatus @default(ON_TRACK)
  requestDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

model PurchaseOrder {
  id               String       @id @default(cuid())
  refNo            String       @unique
  projectId        String
  vendorName       String
  materialName     String
  amount           Decimal?     @db.Decimal(18, 2)
  issuedAt         DateTime?
  expectedDelivery DateTime?
  healthStatus     HealthStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
}

/**
 * --------------------------------------------------------------------------
 * ASSETS
 * --------------------------------------------------------------------------
 */

model Asset {
  id        String @id @default(cuid())
  assetCode String @unique
  projectId String

  name      String
  assetType String

  // Existing text location retained.
  location String?

  // New proper road/street relation.
  roadLocationId String?
  roadLocation   RoadLocation? @relation(fields: [roadLocationId], references: [id], onDelete: SetNull)

  healthStatus HealthStatus @default(ON_TRACK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([healthStatus])
  @@index([roadLocationId])
}
